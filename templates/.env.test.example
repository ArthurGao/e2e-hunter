# Copy to `.env.test` at project root and fill in real values.
# Do NOT commit .env.test to git.

# ── Single-app ─────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
API_URL=http://localhost:3001
TEST_EMAIL=test@example.com
TEST_PASSWORD=your-test-password

# ── Multi-app (uncomment if applicable) ────────────────────────────────
# APP_A_URL=http://localhost:3000
# APP_B_URL=http://localhost:3001
# APP_A_EMAIL=admin@test.com
# APP_A_PASSWORD=admin-password
# APP_B_EMAIL=customer@test.com
# APP_B_PASSWORD=customer-password
# APP_A_AUTH=true
# APP_B_AUTH=true

# ── Optional ───────────────────────────────────────────────────────────
# CI=true
