# Copy to `.env.test` at project root and fill in real values.
# Do NOT commit .env.test to git.

# ── Single-app ─────────────────────────────────────────────────────────
BASE_URL=http://localhost:3000
API_URL=http://localhost:3001
TEST_EMAIL=test@example.com
TEST_PASSWORD=your-test-password

# ── Multi-app (any number of apps) ─────────────────────────────────────
# Set APPS to a comma-separated list of app names. Then, for each name,
# define APP_<NAME>_URL (required) and optionally _EMAIL / _PASSWORD / _AUTH.
# The fixture and auth setup both iterate over APPS — no code changes needed.
#
# Example with 3 apps:
# APPS=admin,agency,candidate
#
# APP_ADMIN_URL=http://localhost:3001
# APP_ADMIN_EMAIL=admin@test.com
# APP_ADMIN_PASSWORD=admin-password
# APP_ADMIN_AUTH=true
#
# APP_AGENCY_URL=http://localhost:3002
# APP_AGENCY_EMAIL=agency@test.com
# APP_AGENCY_PASSWORD=agency-password
# APP_AGENCY_AUTH=true
#
# APP_CANDIDATE_URL=http://localhost:3003
# APP_CANDIDATE_EMAIL=candidate@test.com
# APP_CANDIDATE_PASSWORD=candidate-password
# APP_CANDIDATE_AUTH=true
#
# Optional per-app overrides:
# APP_<NAME>_LOGIN_PATH             — defaults to /login
# APP_<NAME>_SUCCESS_URL_REGEX      — regex source string; defaults to ".*\/"

# ── Multi-actor (N parallel sessions of the same role) ────────────────
# Use when testing broadcast fanout, concurrent edit, race-on-unique,
# or parallel-independence scenarios. See multi-actor.fixture.ts.
# Numbering is continuous from 1; fixture stops at the first missing number.
#
# CANDIDATE_1_EMAIL=candidate1@test.com
# CANDIDATE_1_PASSWORD=...
# CANDIDATE_2_EMAIL=candidate2@test.com
# CANDIDATE_2_PASSWORD=...
# CANDIDATE_3_EMAIL=candidate3@test.com
# CANDIDATE_3_PASSWORD=...

# ── Side-effect testing (optional — for Phase 1G oracles) ─────────────
# TEST_DB_URL=postgresql://user:pass@localhost:5432/testdb
# WEBHOOK_URL=http://localhost:4000/webhook-sink   # local sink for webhook tests

# ── PR-mode (optional — restrict scans to diff against base branch) ──
# When set, e2e-hunter only scans files that changed between HEAD and
# this branch. Dramatically faster. Produces `[PR]`-labeled matrix rows.
# Leave unset for full-repo scans.
#
# E2E_HUNTER_DIFF_BASE=main
# E2E_HUNTER_DIFF_BASE=develop
# E2E_HUNTER_DIFF_BASE=origin/main

# ── Optional ───────────────────────────────────────────────────────────
# CI=true
